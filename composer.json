{
    "name": "satheez/laravel-message-contracts",
    "version": "1.0.0",
    "description": "Define, validate, version, and serialize message contracts shared between Laravel services.",
    "keywords": ["laravel", "message", "contracts", "microservices", "payload", "validation"],
    "homepage": "https://github.com/satheez/laravel-message-contracts",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Satheez",
            "email": "hello@satheez.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "phpstan/phpstan": "^1.0|^2.0",
        "rector/rector": "^1.0|^2.0",
        "spatie/laravel-data": "^4.23"
    },
    "autoload": {
        "psr-4": {
            "Satheez\\MessageContracts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Satheez\\MessageContracts\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Satheez\\MessageContracts\\MessageContractsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse",
        "refactor": "vendor/bin/rector process",
        "refactor:check": "vendor/bin/rector process --dry-run",
        "ci": [
            "@format:test",
            "@refactor:check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "rector/rector": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
